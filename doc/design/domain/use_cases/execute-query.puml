@startuml
title UC execute-query
left to right direction
skinparam packageStyle rectangle
skinparam rectangle {
  BackgroundColor<<Command>> LightBlue
  BackgroundColor<<Aggregate>> Khaki
  BackgroundColor<<Event>> Orange
  BackgroundColor<<Failure>> Tomato
}

actor "Ansible Operator" as operator

package "execute-query" {
  rectangle "QUERY_EXECUTION\n(Aggregate)" as AGG <<Aggregate>>

  rectangle "ExecuteQuery\n(Command)\none statement or an\nordered statement batch,\noptionally with bound args" as CMD_Execute <<Command>>
  rectangle "QueryExecuted\n(Event)\nchanged=true for any\nnon-read-only statement" as EVT_Executed <<Event>>

  rectangle "PredictQueryExecution\n(Command, check mode)" as CMD_Predict <<Command>>
  rectangle "QueryExecutionPredicted\n(Event)\nread-only statements still run;\nany write statement is skipped\nand the whole batch is predicted" as EVT_Predicted <<Event>>

  rectangle "ExecuteQuery\n(Command, invalid bound args)" as CMD_Invalid <<Command>>
  rectangle "QueryExecutionRejected\n(Event, Failure)\nbound args combined with a\nstatement batch, or a\npositional/named argument\ncount mismatch" as EVT_Rejected <<Failure>>

  rectangle "ExecuteQuery\n(Command, bad credentials)" as CMD_BadAuth <<Command>>
  rectangle "QueryExecutionFailed\n(Event, Failure)\nsanitized authentication error,\nno secret values exposed" as EVT_Failed <<Failure>>
}

operator --> CMD_Execute
operator --> CMD_Predict
operator --> CMD_Invalid
operator --> CMD_BadAuth

CMD_Execute --> AGG
AGG --> EVT_Executed

CMD_Predict --> AGG
AGG --> EVT_Predicted

CMD_Invalid --> AGG
AGG --> EVT_Rejected

CMD_BadAuth --> AGG
AGG --> EVT_Failed

note bottom of AGG
  Source scenarios:
  specs/ansible_modules/exasol_query.feature
  specs/ansible_playbook/exasol_query.feature
end note
@enduml
